# Copy this file to `.env` and fill in real values.
# The skill reads these at runtime; never commit your real .env.

# Anthropic API key — used for scene classification and enhancement-prompt generation.
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# fal.ai API key — used for the nano-banana-2/edit enhancement call.
# Get one at: https://fal.ai/dashboard/keys
FAL_API_KEY=
